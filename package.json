    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-relay": "18.2.0"
  },
  "devDependencies": {
    "@swc/core": "^1.10.8",
    "@swc/plugin-relay": "^6.0.4",
    "@typescript-eslint/eslint-plugin": "^5.56.0",
    "clean-webpack-plugin": "^4.0.0",
