    "dev": "relay-compiler && webpack --config webpack.dev.config.js --watch --mode development",
    "build": "relay-compiler && webpack --config webpack.config.js --mode production",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,less}\"",
    "relay": "relay-compiler",
