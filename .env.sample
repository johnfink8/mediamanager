# Database - matches docker-compose.test.yml db service
DB_HOST=db
DB_USER=indexer_utils
DB_PASSWORD=passw0rd
DB_NAME=indexer_utils
# Pytest swaps to this DB (session.py checks sys.argv for pytest).
TEST_DB_NAME=indexer_utils_test

# Redis - matches docker-compose.test.yml redis service
REDIS_HOST=redis

# External services - stub values, not exercised by smoke tests
SONARR_URL=http://sonarr-stub/api/v3
SONARR_APIKEY=test-stub-key
RADARR_URL=http://radarr-stub/api/v3
RADARR_APIKEY=test-stub-key
TMDB_API_KEY=test-stub-key
OPENAI_API_KEY=test-stub-key
INDEXER_URL=http://indexer-stub/
INDEXER_APIKEY=test-stub-key
INDEXER_NUM=1
PLEX_URL=http://plex-stub:32400
PLEX_TOKEN=test-stub-key

# vdiag ffmpeg sidecar (video diagnostic/repair tools). VDIAG_TOKEN is shared:
# docker-compose substitutes it into the vdiag service and the app reads it here.
VDIAG_URL=http://vdiag:9000
VDIAG_TOKEN=test-stub-key
